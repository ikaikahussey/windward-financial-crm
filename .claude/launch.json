{
  "version": "0.0.1",
  "configurations": [
    {
      "name": "API Server",
      "runtimeExecutable": "npm",
      "runtimeArgs": ["run", "dev"],
      "port": 3001,
      "cwd": "packages/api"
    },
    {
      "name": "Admin CRM",
      "runtimeExecutable": "/opt/homebrew/bin/node",
      "env": { "PATH": "/opt/homebrew/bin:/usr/local/bin:/usr/bin:/bin" },
      "runtimeArgs": ["/opt/homebrew/bin/npx", "vite", "--port", "5173"],
      "port": 5173,
      "cwd": "packages/web"
    },
    {
      "name": "Public Website",
      "runtimeExecutable": "npm",
      "runtimeArgs": ["run", "dev"],
      "port": 5174,
      "cwd": "packages/public"
    }
  ]
}
