{
  "name": "@voter-match/api",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "wrangler dev",
    "build": "tsc --noEmit",
    "deploy": "wrangler deploy",
    "test": "vitest run",
    "typecheck": "tsc --noEmit",
    "db:migrate:local": "wrangler d1 migrations apply voter_match --local",
    "db:migrate:remote": "wrangler d1 migrations apply voter_match --remote",
    "db:seed:local": "wrangler d1 execute voter_match --local --file=./migrations/seed.sql",
    "db:seed:remote": "wrangler d1 execute voter_match --remote --file=./migrations/seed.sql"
  },
  "dependencies": {
    "@voter-match/shared": "workspace:*",
    "hono": "^4.4.12"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20240614.0",
    "@types/node": "^20.14.0",
    "esbuild": "^0.21.5",
    "miniflare": "^3.20240610.1",
    "typescript": "^5.4.5",
    "vitest": "^1.6.0",
    "wrangler": "^3.62.0"
  }
}
