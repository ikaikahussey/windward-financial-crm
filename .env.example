DATABASE_URL=postgresql://windward:windward@localhost:5432/windward_crm
SESSION_SECRET=change-me-to-random-string
PORT=3001
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=contact@windwardfinancial.net
SCHEDULING_LINK=https://windward.financial/schedule-an-appointment
QUO_API_KEY=your-quo-api-key-here
QUO_WEBHOOK_BASE_URL=https://your-api-domain.com
ANTHROPIC_API_KEY=your-anthropic-api-key-here
PUBLIC_URL=http://localhost:80
ADMIN_URL=http://localhost:8080

# ── Public Astro site (build-time) ──
# Runtime API base URL for form islands (contact, calculator, schedule, enroll,
# event registration, newsletter subscribe).
PUBLIC_API_URL=http://localhost:3001
# Canonical site URL used for the generated sitemap.
PUBLIC_SITE_URL=https://windward.financial
# Login URL for National Life Group ("Check My Account" CTA).
PUBLIC_NLG_LOGIN_URL=https://nlg-prod.auth0.com/login?audience=https%3A%2F%2Fnlgcpnprdaigw01.azure-api.net%2Fapi&client=PaETxB2EF0hn6xAsyv7g71KarNUJoQvz&connection=NLGCustomerDB&redirect_uri=https%3A%2F%2Fwww.nationallife.com%2Fcustomer%2Fauth%2Flogincallback&response_mode=form_post&response_type=code%20id_token&scope=openid%20profile%20email

# Read-only Postgres role used by the public site at build time to bake
# the events list into static HTML. If unset, the build emits an empty
# events list and logs a warning (useful for CI previews without DB access).
BUILD_DATABASE_URL=

# Webhook the API POSTs to whenever events change, to trigger a rebuild
# of the static public site (e.g. a Railway/Vercel deploy hook). Safe to
# leave unset — the API silently skips when absent.
REBUILD_WEBHOOK_URL=

# ── Admin CRM (build-time) ──
VITE_API_URL=http://localhost:3001
